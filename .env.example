# TeamFlow — Root environment template for Docker Compose
# Copy this file to .env and fill in your local values.
# NEVER commit .env to git.
#
# These hostnames resolve INSIDE the Docker Compose network:
#   postgres / redis / rabbitmq — Docker service names (not localhost)

# Application
ENVIRONMENT=dev

# PostgreSQL — credentials shared between the postgres service and the app
DATABASE_URL=postgresql+asyncpg://teamflow:changeme@postgres:5432/teamflow
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
POSTGRES_USER=teamflow
POSTGRES_PASSWORD=changeme
POSTGRES_DB=teamflow

# Redis
REDIS_URL=redis://redis:6379/0

# RabbitMQ — credentials shared between the rabbitmq service and the app
RABBITMQ_URL=amqp://teamflow:changeme@rabbitmq:5672/
RABBITMQ_USER=teamflow
RABBITMQ_PASSWORD=changeme
