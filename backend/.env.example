# TeamFlow — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# Application
ENVIRONMENT=dev

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://teamflow:teamflow@postgres:5432/teamflow
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
POSTGRES_USER=teamflow
POSTGRES_PASSWORD=changeme
POSTGRES_DB=teamflow

# Redis
REDIS_URL=redis://redis:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://teamflow:changeme@rabbitmq:5672/
RABBITMQ_USER=teamflow
RABBITMQ_PASSWORD=changeme
