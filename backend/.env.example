# TeamFlow — шаблон переменных окружения
# Скопируйте этот файл в .env и заполните реальными значениями.
# НИКОГДА не коммитьте .env в git.

# Приложение
ENVIRONMENT=dev

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://teamflow:teamflow@postgres:5432/teamflow
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
POSTGRES_USER=teamflow
POSTGRES_PASSWORD=changeme
POSTGRES_DB=teamflow

# Redis
REDIS_URL=redis://redis:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://teamflow:changeme@rabbitmq:5672/
RABBITMQ_USER=teamflow
RABBITMQ_PASSWORD=changeme

# JWT — секрет для подписи токенов (минимум 32 символа)
JWT_SECRET=changeme-please-use-a-long-random-secret-32
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800

# Первый суперпользователь — создаётся идемпотентно при старте приложения.
# Пароль: минимум 12 символов, со спецсимволом.
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=ChangeMe123!

# Подпись сессионных cookie SQLAdmin (минимум 32 символа)
ADMIN_SESSION_SECRET=changeme-please-use-a-long-random-secret-32
